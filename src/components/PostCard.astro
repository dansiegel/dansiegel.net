---
import type { Post } from "../lib/posts";
import { formatDate, postPath, readingTime } from "../lib/posts";

interface Props {
  post: Post;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
---

<article class:list={["post-card", { featured }]}>
  <div class="post-card-meta">
    <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
    <span>{readingTime(post)} min read</span>
  </div>
  <h2><a href={postPath(post)}>{post.data.title}</a></h2>
  <p>{post.data.description}</p>
  <div class="post-card-footer">
    <div class="tag-list">
      {post.data.categories.slice(0, 3).map((category) => <span>{category}</span>)}
    </div>
    <a class="text-link" href={postPath(post)} aria-label={`Read ${post.data.title}`}>Read article <span aria-hidden="true">→</span></a>
  </div>
</article>
