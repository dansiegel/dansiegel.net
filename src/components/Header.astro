---
const path = Astro.url.pathname;
const links = [
  { href: "/articles/", label: "Blog" },
  { href: "/open-source/", label: "Open source" },
  { href: "/team-retreats/", label: "Retreats" },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="wordmark" href="/" aria-label="Dan Siegel home">
      <span>dan</span><strong>siegel</strong><i aria-hidden="true">.</i>
    </a>
    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={link.href} aria-current={path.startsWith(link.href) ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>
    <div class="nav-actions">
      <details class="mobile-menu">
        <summary>Menu</summary>
        <nav aria-label="Mobile navigation">
          {links.map((link) => (
            <a href={link.href} aria-current={path.startsWith(link.href) ? "page" : undefined}>{link.label}</a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
